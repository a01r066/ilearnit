rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // Helpers
    // ============================================================

    function isSignedIn() { return request.auth != null; }
    function uid()        { return request.auth.uid; }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }
    function role()       { return userDoc().role; }
    function isSuspended() {
      // Default to `false` if the field is missing.
      return userDoc().get('isSuspended', false) == true;
    }
    function isAdmin() {
      return isSignedIn() && role() == 'admin' && !isSuspended();
    }
    function isInstructor() {
      return isSignedIn()
        && (role() == 'instructor' || role() == 'admin')
        && !isSuspended();
    }
    function isModerator() {
      // Distinct trust level used by the UGC moderation surfaces.
      // Admins are implicitly moderators.
      return isSignedIn()
        && (role() == 'moderator' || role() == 'admin')
        && !isSuspended();
    }

    // ============================================================
    // users/{userId}
    // ============================================================
    match /users/{userId} {
      // Owner reads own doc; admins read all.
      allow read: if isSignedIn() && (uid() == userId || isAdmin());

      // Owner creates own doc on first sign-in.
      allow create: if isSignedIn() && uid() == userId;

      // Owner can write their own non-privileged fields — explicitly
      // NOT role / isSuspended.
      allow update: if isSignedIn()
        && uid() == userId
        && !(request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'isSuspended']));

      // Admins can update anything (including role + isSuspended).
      allow update: if isAdmin();

      allow delete: if isAdmin();

      // --- Lecture progress ------------------------------------------------
      // Per-course rollup at users/{uid}/courseProgress/{courseId} and the
      // per-lecture rows under /lectures/{lectureId}. Owner-only — admins
      // intentionally cannot read these (they're private viewing history).
      match /courseProgress/{courseId} {
        allow read, write: if isSignedIn() && uid() == userId;

        match /lectures/{lectureId} {
          allow read, write: if isSignedIn() && uid() == userId;
        }
      }

      // --- In-app notification inbox --------------------------------------
      // Cloud Functions write new docs via Admin SDK (bypassing rules).
      // From the client we only allow the owner to read, mark-read (set
      // readAt), or delete their own items.
      match /notifications/{notificationId} {
        allow read: if isSignedIn() && uid() == userId;
        allow update: if isSignedIn()
          && uid() == userId
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['readAt']);
        allow delete: if isSignedIn() && uid() == userId;
        // Creates are server-only.
        allow create: if false;
      }

      // --- Wishlist / "Saved courses" -------------------------------------
      // Owner-only by design. Other users cannot see what you've saved.
      // The price-drop Cloud Function uses a collectionGroup query via the
      // Admin SDK and bypasses these rules.
      match /wishlist/{courseId} {
        allow read, write: if isSignedIn() && uid() == userId;
      }

      // --- Private lecture notes ------------------------------------------
      // Owner-only. Notes are personal mnemonics — no admin read access,
      // no cross-user query. Account deletion cleans these up via the
      // `deleteAccount` Cloud Function (Admin SDK bypasses rules).
      match /notes/{noteId} {
        allow read, write: if isSignedIn() && uid() == userId;
      }

      // --- Per-user block list -----------------------------------------
      // users/{uid}/blocks/{blockedUid} — private to the owner. Used by
      // the mobile client to filter UGC lists. No admin access (block
      // lists are private; no business reason for staff to inspect).
      match /blocks/{blockedUid} {
        allow read, write: if isSignedIn() && uid() == userId;
      }
    }

    // ============================================================
    // reports/{reportId} — UGC moderation queue
    // ============================================================
    //
    // Visibility: moderator + admin only. Any signed-in user may
    // submit a report against any other user's content.
    //
    // Mutations after creation are moderator-only (resolve / dismiss).
    // The aggregate counter doc `reports/_aggregates` is maintained by
    // the `onReportCreated` / `onReportResolved` Cloud Functions
    // (Admin SDK bypasses rules).
    match /reports/{reportId} {
      allow read: if isModerator();

      // Submitter must be the signed-in user and the report must enter
      // the queue in `open` state.
      allow create: if isSignedIn()
        && request.resource.data.reporterId == uid()
        && request.resource.data.status == 'open';

      // Only moderators can resolve / dismiss / re-open.
      allow update: if isModerator();

      // Deletes are admin-only (full audit-trail by default).
      allow delete: if isAdmin();
    }

    // ============================================================
    // instructor_applications/{userId}
    // ============================================================
    match /instructor_applications/{userId} {
      allow read: if isSignedIn() && (uid() == userId || isAdmin());

      // Applicant submits / re-applies their own pending application.
      allow create, update: if isSignedIn()
        && uid() == userId
        && request.resource.data.status == 'pending';

      // Admins decide.
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // Catalogue — public read, admin/instructor write
    // ============================================================

    match /courses/{courseId} {
      allow read: if true;

      // ----- Create -----------------------------------------------------
      // Admin can create with any status (e.g. seeding pre-published
      // content). Instructor can only create as their own course AND
      // in `draft` status (or with the field absent — defaults to
      // draft). Stops a malicious instructor client from skipping
      // review by writing `status: 'published'` directly.
      allow create: if isAdmin()
        && (request.resource.data.get('status', 'draft') is string);
      allow create: if isInstructor()
        && request.resource.data.instructorId == uid()
        && request.resource.data.get('status', 'draft') == 'draft';

      // ----- Update -----------------------------------------------------
      // Admin can update anything (any field, any status transition).
      // The CourseStatus state machine in
      // `lib/features/courses/domain/entities/course_status.dart` is
      // the UI source of truth; admin rules are intentionally
      // permissive so admins can hot-fix bad state from the console.
      allow update: if isAdmin();

      // Instructor can update their OWN course only, and only:
      //   • Without touching admin-only fields (isFeatured,
      //     enrollmentCount, publishedAt, archivedAt, instructorId).
      //   • With status either unchanged (normal metadata edits)
      //     OR transitioning along the legal instructor edge:
      //     draft → submitted, or changes_requested → submitted.
      //
      // Mirrors `CourseStatus.allowedNextStates('instructor')` —
      // those two transitions are the only ones returned for the
      // instructor role. Updating any other status code from the
      // instructor client fails rules.
      allow update: if isInstructor()
        && resource.data.instructorId == uid()
        && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny([
                'isFeatured',
                'enrollmentCount',
                'publishedAt',
                'archivedAt',
                'instructorId',
              ])
        && (
          // Status untouched: any other metadata edit is fine.
          !request.resource.data.diff(resource.data)
              .affectedKeys().hasAny(['status'])
          ||
          // Legal instructor transition: draft / changes_requested → submitted.
          (resource.data.get('status', 'draft') in
                ['draft', 'changes_requested']
            && request.resource.data.status == 'submitted')
        );

      // Delete:
      //   • Admin can delete anything (escape hatch for hard cleanup).
      //   • Instructor can ONLY delete their own course while it's
      //     still in `draft`. Once it's left draft (submitted, under
      //     review, approved, changes_requested, published,
      //     unpublished, archived) only an admin can delete it. This
      //     matches the workflow expectation that:
      //       - Drafts are a sandbox; instructors can throw them away.
      //       - Anything submitted enters the review pipeline and is
      //         owned by editorial review from then on. An instructor
      //         changing their mind about a submitted course pulls it
      //         back via the "Send back to draft" admin path or asks
      //         an admin to archive it.
      //       - Anything published has student-side traces
      //         (enrollments, reviews, lecture progress). Direct
      //         delete by the instructor would orphan that data;
      //         archive is the correct shape, and that's admin-only.
      //
      // `.get('status', 'draft')` covers legacy docs written before
      // the field existed — they read as draft, which preserves the
      // pre-workflow delete behaviour for the small handful of
      // courses that pre-date this refactor.
      allow delete: if isAdmin();
      allow delete: if isInstructor()
        && resource.data.instructorId == uid()
        && resource.data.get('status', 'draft') == 'draft';

      // The reviews aggregator (rating + reviewCount) is rewritten by the
      // client when a review is created/deleted. Allow signed-in users to
      // bump those two fields without granting them a full update.
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['rating', 'reviewCount']);

      // --- Reviews -------------------------------------------------------
      // Read: public. Write: only the author (doc id == uid). The UI gates
      // who can open the WriteReviewSheet via `hasUnlockedAccessProvider`
      // (purchased OR active subscription); this rule trusts that gate but
      // still constrains shape + ownership.
      //
      // Note: rules cannot yet enforce "purchased OR subscribed" because
      // the enrollment doc id format isn't deterministic. Once enrollments
      // are written at `enrollments/{uid}_{courseId}`, swap this rule to
      // include an `exists(...)` check on that path.
      match /reviews/{userId} {
        allow read: if true;
        allow create, update: if isSignedIn()
          && uid() == userId
          && request.resource.data.userId == uid()
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5;
        allow delete: if isAdmin()
          || (isSignedIn() && uid() == userId);
      }

      match /sections/{sectionId} {
        allow read: if true;
        allow write: if isAdmin()
          || (isInstructor()
              && get(/databases/$(database)/documents/courses/$(courseId))
                   .data.instructorId == uid());

        match /lectures/{lectureId} {
          allow read: if true;
          allow write: if isAdmin()
            || (isInstructor()
                && get(/databases/$(database)/documents/courses/$(courseId))
                     .data.instructorId == uid());

          // --- Q&A: per-lecture questions ---------------------------------
          // Public read so unauthenticated browsers can see what learners
          // are asking (drives course discovery). Writes are author-only,
          // with two carve-outs:
          //   1. Any signed-in user who just posted a reply can bump
          //      `replyCount` (FieldValue.increment) on the parent
          //      question. We can't actually validate the increment
          //      amount in rules — we trust the client to bump by ±1.
          //   2. An instructor reply also flips `isInstructorAnswered` to
          //      true; rules allow any signed-in user to set this true
          //      because verifying "this writer just authored an
          //      instructor reply" would require a cross-collection
          //      lookup that's not cheap. The badge itself is locked at
          //      reply-write time via the denormalized `isInstructor`
          //      field on the reply doc.
          match /questions/{questionId} {
            allow read: if true;

            allow create: if isSignedIn()
              && request.resource.data.userId == uid()
              && request.resource.data.body is string
              && request.resource.data.body.size() >= 5
              && request.resource.data.body.size() <= 2000;

            // Author edits their own body / updatedAt.
            allow update: if isSignedIn()
              && resource.data.userId == uid()
              && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['body', 'updatedAt']);

            // Aggregator carve-out: any signed-in user can bump
            // replyCount + isInstructorAnswered (pair with the reply
            // create). Admin override below for moderation.
            allow update: if isSignedIn()
              && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['replyCount', 'isInstructorAnswered']);

            // Course's instructor or admin can hard-delete / moderate.
            allow update, delete: if isAdmin()
              || (isInstructor()
                  && get(/databases/$(database)/documents/courses/$(courseId))
                       .data.instructorId == uid());

            // Author can delete their own thread.
            allow delete: if isSignedIn() && resource.data.userId == uid();

            // --- Replies subcollection ------------------------------------
            match /replies/{replyId} {
              allow read: if true;

              allow create: if isSignedIn()
                && request.resource.data.userId == uid()
                && request.resource.data.body is string
                && request.resource.data.body.size() >= 1
                && request.resource.data.body.size() <= 2000
                // `isInstructor: true` is only allowed if the writer
                // truly is the course's instructor (or an admin).
                // Prevents student impersonation of the verified badge.
                && (
                  request.resource.data.isInstructor == false
                  || isAdmin()
                  || get(/databases/$(database)/documents/courses/$(courseId))
                       .data.instructorId == uid()
                );

              allow update: if isSignedIn()
                && resource.data.userId == uid()
                && request.resource.data.diff(resource.data).affectedKeys()
                    .hasOnly(['body', 'updatedAt']);

              allow delete: if isAdmin()
                || (isSignedIn() && resource.data.userId == uid())
                || (isInstructor()
                    && get(/databases/$(database)/documents/courses/$(courseId))
                         .data.instructorId == uid());
            }
          }
        }
      }
    }

    match /instructors/{instructorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Learning paths (editorial product, admin-managed) ----------------
    // Public read of every path including drafts is fine — the consumer
    // datasource filters by `isPublished == true`, and we don't write any
    // sensitive metadata that would leak from an unpublished doc. Admin
    // write only.
    match /learning_paths/{pathId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /songbooks/{songbookId} {
      allow read: if true;
      allow write: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == uid();
        allow update, delete: if isAdmin()
          || (isSignedIn() && resource.data.userId == uid());
      }
    }

    // ============================================================
    // enrollments/{enrollmentId}
    // ============================================================
    match /enrollments/{enrollmentId} {
      // Instructors get to see enrollments on THEIR OWN courses (so the
      // /my-students page works) via a course-doc cross-reference. The
      // get() costs one extra read per matching enrollment, which is
      // fine for an admin-only page. Single-doc reads are cheap;
      // collection queries with the same filter pay get() per result.
      allow read: if isSignedIn() && (
        resource.data.userId == uid()
        || isAdmin()
        || (isInstructor()
            && get(/databases/$(database)/documents/courses/$(resource.data.courseId))
                 .data.instructorId == uid())
      );
      allow create: if isSignedIn()
        && request.resource.data.userId == uid();
      // Admin can update enrollment.status (e.g. → 'cancelled' as part
      // of a refund) and delete outright.
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // transactions/{transactionId}
    // ============================================================
    // Purchase records. Created server-side by the (future) IAP
    // receipt-verifier Cloud Function and mutated only by admin via
    // the processRefund callable. The Admin SDK bypasses these rules
    // for the Cloud Function path; what's enforced here is what
    // clients can see.
    match /transactions/{transactionId} {
      // The student who paid can see their own transaction.
      // The instructor who taught the course can see it.
      // Admin sees everything. Anyone else: denied.
      allow read: if isSignedIn() && (
        resource.data.studentUid == uid()
        || resource.data.instructorId == uid()
        || isAdmin()
      );
      // Clients NEVER write transactions directly. Even admins are
      // gated through the processRefund Cloud Function (audit trail).
      allow create, update, delete: if false;
    }

    // ============================================================
    // payouts/{payoutId}
    // ============================================================
    // Periodic per-instructor payout record. Bookkeeping only in v1.
    match /payouts/{payoutId} {
      allow read: if isSignedIn() && (
        resource.data.instructorUid == uid()
        || isAdmin()
      );
      // Create / update gated to admin; the markPayoutPaid callable
      // also runs as admin so it's covered by isAdmin() here.
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // site_content/{slug}  — landing-page CMS
    // ============================================================
    // Public read so the static marketing site (anonymous web users)
    // can pull the latest doc from JS. Admin-only write — instructors
    // can't tamper with the landing page.
    match /site_content/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // notification_broadcasts/{broadcastId}
    // ============================================================
    // Admin queues a broadcast. The Cloud Function picks it up and writes
    // the result back; the function uses the Admin SDK and bypasses these
    // rules entirely.
    match /notification_broadcasts/{broadcastId} {
      allow read:   if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.createdBy == uid()
        && request.resource.data.status == 'pending';
      allow update: if false; // only the Function (Admin SDK) writes
      allow delete: if isAdmin();
    }
  }
}
